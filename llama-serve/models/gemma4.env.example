# Copy this file to models/<name>.env and edit values.
# Example: models/qwen.env, models/gpt-oss.env

MODEL_NAME=example
MODEL_ALIAS=example-local
MODEL_PATH=/absolute/path/to/model.gguf
MMPROJ_PATH=/absolute/path/to/mmproj.gguf
MMPROJ_OFFLOAD=on
CTX_SIZE=32768
CHAT_TEMPLATE=google-gemma-4-31B-it.jinja
CACHE_REUSE=256
PARALLEL=1
FLASH_ATTN=on
BATCH_SIZE=1024
UBATCH_SIZE=256
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0
REASONING=off
# Optional image budget clamps for dynamic-resolution vision models.
# IMAGE_MIN_TOKENS=140
# IMAGE_MAX_TOKENS=560
# Optional extra llama-server flags split on shell whitespace.
# EXTRA_ARGS=--main-gpu 0
