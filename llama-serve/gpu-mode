#!/usr/bin/env bash
set -euo pipefail

mode="${1:-status}"
owner="${2:-}"
base="http://127.0.0.1:8090"

case "$mode" in
  status)
    exec curl -fsS "$base/admin/status"
    ;;
  auto)
    exec curl -fsS -X POST "$base/admin/release?owner=game"
    ;;
  warm)
    exec curl -fsS -X POST "$base/admin/warm"
    ;;
  game)
    exec curl -fsS -X POST "$base/admin/acquire?owner=game"
    ;;
  acquire)
    [[ -n "$owner" ]] || { echo "usage: gpu-mode acquire <owner>" >&2; exit 2; }
    exec curl -fsS -X POST "$base/admin/acquire?owner=$owner"
    ;;
  release)
    [[ -n "$owner" ]] || { echo "usage: gpu-mode release <owner>" >&2; exit 2; }
    exec curl -fsS -X POST "$base/admin/release?owner=$owner"
    ;;
  *)
    echo "usage: gpu-mode {status|warm|game|auto|acquire <owner>|release <owner>}" >&2
    exit 2
    ;;
esac
